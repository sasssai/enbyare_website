{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "enbyare",
  "main": "src/index.js",
  "compatibility_date": "2026-05-16",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  }
}
